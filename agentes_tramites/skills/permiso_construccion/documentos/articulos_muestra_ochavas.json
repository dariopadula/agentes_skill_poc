                          "fecha_consulta":  "2026-06-24"
                      },
                      {
                          "id":  "articulo_81848",
                          "node_id":  "81848",
                          "numero":  "D.3193",
                          "estado":  "vigente",
                          "titulo":  null,
                          "texto":  "Se establece: \na) que en el caso que las alineaciones formen un ángulo agudo, la ochava reglamentaria será la que resulta de tomar tres metros cincuenta y tres centímetros sobre ambas alineaciones a partir del vértice y unir los puntos así determinados por medio de una recta; \nb) que cuando las alineaciones formen ángulos obtusos iguales o mayores que ciento treinta y cinco grados no se exigirá la construcción de la ochava.",
                          "url":  "https://normativa.montevideo.gub.uy/articulo/81848",
