                      },
                      {
                          "id":  "articulo_77702",
                          "node_id":  "77702",
                          "numero":  "D.3187",
                          "estado":  "vigente",
                          "titulo":  null,
                          "texto":  "La dimensión de esa ochava será de cinco metros como mínimo, para los lugares fraccionados con anterioridad al 26 de marzo de 1957 y que por el plan de calles y de división en solares, no tengan por resolución especial, la obligación de una dimensión mayor.",
                          "url":  "https://normativa.montevideo.gub.uy/articulo/77702",
                          "fuente_armado":  "https://normativa.montevideo.gub.uy/armado/82663",
                          "jerarquia":  {
                                            "volumen":  "Volumen XV Planeamiento de la Edificación",
                                            "parte":  "Parte Legislativa",
                                            "libro":  "Libro XV Planeamiento de la Edificación",
                                            "titulo":  "Título I Normas generales para proyecto",
                                            "capitulo":  "Capítulo I De las ochavas",
                                            "seccion":  null
                                        },
                          "fuentes":  [
                                          {
                                              "nombre":  "OM de 22.06.1931",
                                              "url":  "https://normativa.montevideo.gub.uy/content/om-de-22061931-3",
                                              "referencia":  "art. 2",
                                              "observaciones":  ""
                                          }
                                      ],
                          "fecha_consulta":  "2026-06-24"
                      },
                      {
                          "id":  "articulo_77703",
                          "node_id":  "77703",
                          "numero":  "D.3188",
                          "estado":  "vigente",
                          "titulo":  null,
                          "texto":  "Para los futuros trazados de calles y división en solares de terrenos que estén situados fuera de centros urbanos será obligatorio una ochava de ocho metros, como mínimo.",
                          "url":  "https://normativa.montevideo.gub.uy/articulo/77703",
                          "fuente_armado":  "https://normativa.montevideo.gub.uy/armado/82663",
                          "jerarquia":  {
                                            "volumen":  "Volumen XV Planeamiento de la Edificación",
                                            "parte":  "Parte Legislativa",
                                            "libro":  "Libro XV Planeamiento de la Edificación",
                                            "titulo":  "Título I Normas generales para proyecto",
                                            "capitulo":  "Capítulo I De las ochavas",
                                            "seccion":  null
                                        },
                          "fuentes":  [
                                          {
                                              "nombre":  "OM de 22.06.1931",
                                              "url":  "https://normativa.montevideo.gub.uy/content/om-de-22061931-3",
                                              "referencia":  "art. 3",
                                              "observaciones":  ""
